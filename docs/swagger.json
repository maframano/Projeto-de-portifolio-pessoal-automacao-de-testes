{
  "openapi": "3.0.0",
  "info": {
    "title": "API EBD - Escola Bíblica Dominical",
    "version": "1.0.0",
    "description": "API para acompanhamento de frequência de alunos na Escola Bíblica Dominical."
  },
  "tags": [
    { "name": "Cadastro", "description": "Endpoints de cadastro de secretária, professor e aluno" },
    { "name": "Secretaria", "description": "Operações de secretária" },
    { "name": "Professor", "description": "Operações de professor" },
    { "name": "Aluno", "description": "Operações de aluno" },
    { "name": "Autenticação", "description": "Login e autenticação" },
    { "name": "Presença", "description": "Operações de presença" },
    { "name": "Relatório", "description": "Relatórios diversos" }
  ],
  "servers": [
    { "url": "http://localhost:3000" }
  ],
  "paths": {
    "/secretaria": {
      "post": {
        "tags": ["Cadastro"],
        "summary": "Cadastrar secretária",
        "responses": { "201": { "description": "Secretária cadastrada" } }
      },
      "get": {
        "tags": ["Secretaria"],
        "summary": "Listar secretárias",
        "responses": { "200": { "description": "Lista de secretárias" } }
      }
    },
    "/professores": {
      "post": {
        "tags": ["Cadastro"],
        "summary": "Cadastrar professor",
        "responses": { "201": { "description": "Professor cadastrado" } }
      },
      "get": {
        "tags": ["Professor"],
        "summary": "Listar professores",
        "responses": { "200": { "description": "Lista de professores" } }
      }
    },
    "/alunos": {
      "post": {
        "tags": ["Cadastro"],
        "summary": "Cadastrar aluno",
        "responses": { "201": { "description": "Aluno cadastrado" } }
      },
      "get": {
        "tags": ["Aluno"],
        "summary": "Listar alunos",
        "responses": { "200": { "description": "Lista de alunos" } }
      }
    },
    "/auth/login": {
      "post": {
        "tags": ["Autenticação"],
        "summary": "Login da secretária",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": { "type": "string" },
                  "senha": { "type": "string" }
                },
                "required": ["email", "senha"]
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Token JWT gerado" },
          "401": { "description": "Credenciais inválidas" }
        }
      }
    },
    "/presencas": {
      "get": {
        "tags": ["Presença"],
        "summary": "Listar presenças",
        "responses": { "200": { "description": "Lista de presenças" } }
      },
      "post": {
        "tags": ["Presença"],
        "summary": "Registrar presença",
        "responses": { "201": { "description": "Presença registrada" } }
      }
    },
    "/relatorios/presencas/domingo/{data}": {
      "get": {
        "tags": ["Relatório"],
        "summary": "Presença por classe em um domingo",
        "parameters": [{ "name": "data", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Presença por classe" } }
      }
    },
    "/relatorios/presencas/trimestre/{ano}/{trimestre}": {
      "get": {
        "tags": ["Relatório"],
        "summary": "Presença acumulada por classe no trimestre",
        "parameters": [
          { "name": "ano", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "trimestre", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": { "200": { "description": "Presença acumulada por classe" } }
      }
    },
    "/relatorios/vencedores/trimestre/{ano}/{trimestre}": {
      "get": {
        "tags": ["Relatório"],
        "summary": "Classe vencedora e aluno ganhador por classe no trimestre",
        "parameters": [
          { "name": "ano", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "trimestre", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": { "200": { "description": "Classe vencedora e aluno ganhador por classe" } }
      }
    },
    "/relatorios/aniversariantes": {
      "get": {
        "tags": ["Relatório"],
        "summary": "Lista de aniversariantes",
        "responses": { "200": { "description": "Lista de aniversariantes" } }
      }
    }
  }
}
