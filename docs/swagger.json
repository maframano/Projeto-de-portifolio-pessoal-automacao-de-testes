{
  "openapi": "3.0.0",
  "info": {
    "title": "API EBD - Escola Bíblica Dominical",
    "version": "1.0.0",
    "description": "API para acompanhamento de frequência de alunos na Escola Bíblica Dominical."
  },
  "servers": [
    { "url": "http://localhost:3000" }
  ],
  "paths": {
    "/auth/login": {
      "post": {
        "summary": "Login da secretária",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": { "type": "string" },
                  "senha": { "type": "string" }
                },
                "required": ["email", "senha"]
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Token JWT gerado" },
          "401": { "description": "Credenciais inválidas" }
        }
      }
    },
    "/alunos": {
      "get": { "summary": "Listar alunos", "responses": { "200": { "description": "Lista de alunos" } } },
      "post": { "summary": "Cadastrar aluno", "responses": { "201": { "description": "Aluno cadastrado" } } }
    },
    "/professores": {
      "get": { "summary": "Listar professores", "responses": { "200": { "description": "Lista de professores" } } },
      "post": { "summary": "Cadastrar professor", "responses": { "201": { "description": "Professor cadastrado" } } }
    },
    "/secretaria": {
      "get": { "summary": "Listar secretárias", "responses": { "200": { "description": "Lista de secretárias" } } },
      "post": { "summary": "Cadastrar secretária", "responses": { "201": { "description": "Secretária cadastrada" } } }
    },
    "/presencas": {
      "get": { "summary": "Listar presenças", "responses": { "200": { "description": "Lista de presenças" } } },
      "post": { "summary": "Registrar presença", "responses": { "201": { "description": "Presença registrada" } } }
    },
    "/relatorios/presencas/domingo/{data}": {
      "get": { "summary": "Presença por classe em um domingo", "parameters": [{ "name": "data", "in": "path", "required": true, "schema": { "type": "string" } }], "responses": { "200": { "description": "Presença por classe" } } }
    },
    "/relatorios/presencas/trimestre/{ano}/{trimestre}": {
      "get": { "summary": "Presença acumulada por classe no trimestre", "parameters": [
        { "name": "ano", "in": "path", "required": true, "schema": { "type": "string" } },
        { "name": "trimestre", "in": "path", "required": true, "schema": { "type": "string" } }
      ], "responses": { "200": { "description": "Presença acumulada por classe" } } }
    },
    "/relatorios/vencedores/trimestre/{ano}/{trimestre}": {
      "get": { "summary": "Classe vencedora e aluno ganhador por classe no trimestre", "parameters": [
        { "name": "ano", "in": "path", "required": true, "schema": { "type": "string" } },
        { "name": "trimestre", "in": "path", "required": true, "schema": { "type": "string" } }
      ], "responses": { "200": { "description": "Classe vencedora e aluno ganhador por classe" } } }
    },
    "/relatorios/aniversariantes": {
      "get": { "summary": "Lista de aniversariantes", "responses": { "200": { "description": "Lista de aniversariantes" } } }
    }
  }
}
